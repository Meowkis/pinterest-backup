{
  "name": "pinterest-backup",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pinterest board backup service",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts daemon",
    "auth": "tsx src/cli.ts auth",
    "sync": "tsx src/cli.ts sync",
    "start": "node dist/cli.js daemon",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
