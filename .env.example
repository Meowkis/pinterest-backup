PINTEREST_EMAIL=you@example.com
# Prefer PINTEREST_PASSWORD_FILE in Docker instead of this variable.
PINTEREST_PASSWORD=
PINTEREST_PASSWORD_FILE=./secrets/pinterest_password.txt
PINTEREST_USERNAME=
PINTEREST_HEADLESS=true
AUTH_TIMEOUT_SECONDS=60
SYNC_INTERVAL_HOURS=3
SYNC_ON_START=true
DOWNLOAD_CONCURRENCY=3
DATA_DIR=./data
TZ=Europe/Moscow
